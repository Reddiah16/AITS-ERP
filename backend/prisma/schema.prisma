generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// CORE MODELS
// ─────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  password     String
  name         String
  role         String   @default("student") // super_admin, admin, hod, faculty, student
  avatar       String?
  phone        String?
  rollNumber   String?  @unique
  employeeId   String?  @unique
  isActive     Boolean  @default(true)
  isApproved   Boolean  @default(false)
  refreshToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  student          Student?
  faculty          Faculty?
  notifications    NotificationRecipient[]
  auditLogs        AuditLog[]
  issuedCirculars  Circular[]             @relation("CircularIssuedBy")
  sentNotifications Notification[]        @relation("NotificationCreatedBy")
}

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  code        String   @unique
  description String?
  hodId       String?  @unique
  logo        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hod         Faculty?   @relation("DepartmentHOD", fields: [hodId], references: [id])
  faculties   Faculty[]  @relation("DepartmentFaculties")
  students    Student[]  @relation("DepartmentStudents")
  programs    Program[]
  subjects    Subject[]
  gallery     GalleryImage[]
}

model Program {
  id           String   @id @default(cuid())
  name         String
  code         String
  duration     Int      @default(4)
  departmentId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  students     Student[]
}

model Subject {
  id           String   @id @default(cuid())
  name         String
  code         String   @unique
  credits      Int      @default(3)
  semester     Int      @default(1)
  departmentId String
  facultyId    String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department   Department   @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  faculty      Faculty?     @relation("FacultySubjects", fields: [facultyId], references: [id])
  attendance   Attendance[]
  internalMarks InternalMark[]
}

model Student {
  id            String    @id @default(cuid())
  userId        String    @unique
  rollNumber    String    @unique
  enrollmentNo  String    @unique
  departmentId  String
  programId     String?
  semester      Int       @default(1)
  year          Int       @default(1)
  section       String?
  batch         String?
  phone         String?
  address       String?
  dob           DateTime?
  gender        String?
  bloodGroup    String?
  guardianName  String?
  guardianPhone String?
  admissionDate DateTime  @default(now())
  status        String    @default("active")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  department        Department         @relation("DepartmentStudents", fields: [departmentId], references: [id])
  program           Program?           @relation(fields: [programId], references: [id])
  documents         Document[]
  attendance        Attendance[]
  internalMarks     InternalMark[]
  semesterResults   SemesterResult[]
  hallTickets       HallTicket[]
  placementApps     PlacementApplication[]
  bookIssues        BookIssue[]
  studentPredictions StudentPrediction[]
  placementPredictions PlacementPrediction[]
  attendanceAnalytics AttendanceAnalytic[]
}

model Faculty {
  id             String   @id @default(cuid())
  userId         String   @unique
  employeeId     String   @unique
  departmentId   String
  designation    String?
  specialization String?
  qualification  String?
  experience     Int      @default(0)
  phone          String?
  address       String?
  dob            DateTime?
  gender         String?
  joinDate       DateTime @default(now())
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  department      Department   @relation("DepartmentFaculties", fields: [departmentId], references: [id])
  departments     Department[] @relation("DepartmentHOD")
  subjects        Subject[]    @relation("FacultySubjects")
  markedAttendance Attendance[] @relation("AttendanceMarkedBy")
  enteredMarks    InternalMark[] @relation("MarksEnteredBy")
}

// ─────────────────────────────────────────────────────────────
// ATTENDANCE
// ─────────────────────────────────────────────────────────────

model Attendance {
  id         String   @id @default(cuid())
  studentId  String
  subjectId  String
  date       DateTime
  status     String   @default("present") // present, absent, late
  markedById String?
  remarks    String?
  createdAt  DateTime @default(now())

  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject    Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  markedBy   Faculty? @relation("AttendanceMarkedBy", fields: [markedById], references: [id])

  @@unique([studentId, subjectId, date])
}

// ─────────────────────────────────────────────────────────────
// COMMUNICATIONS
// ─────────────────────────────────────────────────────────────

model Notification {
  id         String   @id @default(cuid())
  title      String
  message    String
  type       String   @default("info")
  targetRole String?
  createdById String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  createdBy  User                    @relation("NotificationCreatedBy", fields: [createdById], references: [id])
  recipients NotificationRecipient[]
}

model NotificationRecipient {
  id             String   @id @default(cuid())
  notificationId String
  userId         String
  isRead         Boolean  @default(false)
  readAt         DateTime?

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
}

model Circular {
  id         String   @id @default(cuid())
  title      String
  content    String
  type       String   @default("general")
  targetRole String?
  fileUrl    String?
  issuedById String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  issuedBy   User     @relation("CircularIssuedBy", fields: [issuedById], references: [id])
}

// ─────────────────────────────────────────────────────────────
// EXAMINATION MODULE
// ─────────────────────────────────────────────────────────────

model InternalMark {
  id          String   @id @default(cuid())
  studentId   String
  subjectId   String
  examType    String
  marks       Float
  maxMarks    Float    @default(30)
  enteredById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  enteredBy   Faculty? @relation("MarksEnteredBy", fields: [enteredById], references: [id])

  @@unique([studentId, subjectId, examType])
}

model SemesterResult {
  id           String   @id @default(cuid())
  studentId    String
  semester     Int
  gpa          Float?
  sgpa         Float?
  totalCredits Int      @default(0)
  status       String   @default("pending")
  publishedAt  DateTime?
  createdAt    DateTime @default(now())

  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, semester])
}

model HallTicket {
  id          String   @id @default(cuid())
  studentId   String
  semester    Int
  examMonth   String
  isGenerated Boolean  @default(false)
  generatedAt DateTime?
  createdAt   DateTime @default(now())

  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, semester, examMonth])
}

// ─────────────────────────────────────────────────────────────
// PLACEMENT MODULE
// ─────────────────────────────────────────────────────────────

model Company {
  id        String   @id @default(cuid())
  name      String
  industry  String?
  website   String?
  logo      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  drives    PlacementDrive[]
}

model PlacementDrive {
  id            String   @id @default(cuid())
  companyId     String
  title         String
  description   String?
  driveDate     DateTime
  registrationDeadline DateTime?
  eligibility   String?
  ctcOffered    String?
  location      String?
  status        String   @default("upcoming")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company       Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  applications  PlacementApplication[]
}

model PlacementApplication {
  id        String   @id @default(cuid())
  studentId String
  driveId   String
  resumeUrl String?
  status    String   @default("applied")
  appliedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student   Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  drive     PlacementDrive @relation(fields: [driveId], references: [id], onDelete: Cascade)

  @@unique([studentId, driveId])
}

// ─────────────────────────────────────────────────────────────
// LIBRARY MODULE
// ─────────────────────────────────────────────────────────────

model LibraryBook {
  id          String   @id @default(cuid())
  title       String
  author      String
  isbn        String?  @unique
  publisher   String?
  category    String?
  quantity    Int      @default(1)
  available   Int      @default(1)
  location    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  issues      BookIssue[]
}

model BookIssue {
  id          String    @id @default(cuid())
  bookId      String
  studentId   String
  issueDate   DateTime  @default(now())
  dueDate     DateTime
  returnDate  DateTime?
  fine        Float     @default(0)
  status      String    @default("issued")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  book        LibraryBook @relation(fields: [bookId], references: [id], onDelete: Cascade)
  student     Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────
// GALLERY MODULE
// ─────────────────────────────────────────────────────────────

model GalleryImage {
  id           String   @id @default(cuid())
  title        String
  description  String?
  imageUrl     String
  category     String   @default("campus")
  departmentId String?
  uploadedById String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  department   Department? @relation(fields: [departmentId], references: [id])
}

// ─────────────────────────────────────────────────────────────
// SYSTEM
// ─────────────────────────────────────────────────────────────

model Document {
  id         String   @id @default(cuid())
  name       String
  type       String
  fileUrl    String
  studentId  String
  uploadedAt DateTime @default(now())

  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id])
}

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model HeroBanner {
  id        String   @id @default(cuid())
  title     String
  subtitle  String?
  imageUrl  String
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Report {
  id          String   @id @default(cuid())
  title       String
  type        String
  format      String
  generatedBy String
  fileUrl     String?
  parameters  String?
  createdAt   DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────
// AI PREDICTIONS
// ─────────────────────────────────────────────────────────────

model StudentPrediction {
  id                  String   @id @default(cuid())
  studentId           String
  performanceStatus   String
  failureRiskPercent  Float
  gpaForecast         Float
  gpaSemester         Int
  predictionDate      DateTime @default(now())

  student             Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model PlacementPrediction {
  id                  String   @id @default(cuid())
  studentId           String
  probabilityPercent  Float
  recommendedSkills   String
  recommendedResumes  String?
  predictionDate      DateTime @default(now())

  student             Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model AttendanceAnalytic {
  id                  String   @id @default(cuid())
  studentId           String
  trend               String
  predictedAttendance Float
  predictionDate      DateTime @default(now())

  student             Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}
